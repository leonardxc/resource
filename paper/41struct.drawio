        <mxCell id="layer_cache" value="四 (B). 高可用缓存子系统 (Distributed Cache Subsystem)" style="swimlane;horizontal=0;whiteSpace=wrap;html=1;startSize=40;fillColor=#f8f9fa;fontStyle=1;fontSize=14;" vertex="1" parent="1">
