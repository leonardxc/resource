        </mxCell>

        <mxCell id="s5_struct" value="&lt;b&gt;ActionResult 解析&lt;/b&gt;&lt;br&gt;├── exit_code: int&lt;br&gt;├── stdout_digest: Digest&lt;br&gt;├── stderr_digest: Digest&lt;br&gt;└── output_files[]:&lt;br&gt;    ├── path: string (本地相对路径)&lt;br&gt;    ├── digest: Digest (指向内容)&lt;br&gt;    └── is_executable: bool" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;strokeWidth=1.5;fontFamily=Helvetica;align=left;spacingLeft=15;" vertex="1" parent="s5_bg">
