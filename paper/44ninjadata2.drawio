        <mxCell id="s4_exec_srv" value="&lt;b&gt;Execution Server (REAPI gRPC)&lt;/b&gt;&lt;br&gt;1. 解析 Action，获取 input_root_digest&lt;br&gt;2. 从 CAS 下载源文件与依赖&lt;br&gt;3. 创建隔离执行沙箱环境&lt;br&gt;4. 执行编译命令 (如 clang -c ...)&lt;br&gt;5. 收集沙箱输出文件，上传回 CAS&lt;br&gt;6. 返回 ActionResult 结构" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;strokeWidth=2;fontFamily=Helvetica;align=left;spacingLeft=15;" vertex="1" parent="s4_bg">
          <mxGeometry x="210" y="110" width="290" height="150" as="geometry" />
        </mxCell>

        <mxCell id="s4_executor" value="&lt;b&gt;Executor 执行器物理节点&lt;/b&gt;&lt;br&gt;沙箱容器环境结构：&lt;br&gt;├── input_root/ (从 CAS 挂载的输入)&lt;br&gt;├── 执行触发脚本 (sh / cmd)&lt;br&gt;└── outputs/ (生成的 .o, .d 文件)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#333333;strokeWidth=1.5;fontFamily=Helvetica;align=left;spacingLeft=15;" vertex="1" parent="s4_bg">
