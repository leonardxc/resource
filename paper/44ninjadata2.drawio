        <mxCell id="arr_4_5" value="&lt;b&gt;输出: ActionResult { exit_code, stdout_digest, output_files[] }&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#333333;strokeWidth=2;endArrow=block;endFill=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontFamily=Helvetica;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="s4_bg" target="s5_bg">
