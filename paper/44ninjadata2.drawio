        <mxCell id="s5_bg" value="&lt;b&gt;阶段 5: 结果下载 (Result Download)&lt;/b&gt;" style="swimlane;horizontal=1;whiteSpace=wrap;html=1;fillColor=#f8f8f8;strokeColor=#333333;strokeWidth=1.5;startSize=30;collapsible=0;fontFamily=Helvetica;" vertex="1" parent="1">
